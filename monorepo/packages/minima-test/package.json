{
  "name": "minima-test",
  "version": "0.1.0",
  "description": "Testing framework for Minima KISS VM smart contracts",
  "keywords": ["minima", "blockchain", "kissvm", "testing", "smart-contracts"],
  "author": "Minima Developer Toolkit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaroslawfejdasz/-KISS-VM-interpreter.git",
    "directory": "monorepo/packages/minima-test"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "minima-test": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/index.test.js 2>/dev/null || node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=src",
    "test:src": "npx tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0"
  }
}
